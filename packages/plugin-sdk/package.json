{
  "name": "@302ai/studio-plugin-sdk",
  "version": "1.0.0",
  "description": "Plugin SDK for 302.AI Studio - Build plugins for AI chat application",
  "type": "module",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --out-dir dist",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "ai": ">=5.0.0"
  },
  "dependencies": {
    "tsup": "^8.0.0",
    "rimraf": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
